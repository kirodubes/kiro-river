#!/bin/sh
# ════════════════════════════════════════════════════════════════════════
# Kiro river baseline config  (~/.config/river/init)
# ════════════════════════════════════════════════════════════════════════
# Target: river-classic (the dynamic-tiling river — ships riverctl + rivertile).
# Kiro's "classic dynamic tiling, dwm/xmonad-style" Wayland edition.
#
# river's config IS this executable shell script: it must be `chmod +x`. It holds
# both configuration (riverctl map / set-option) and — via scripts/autostart.sh —
# the session autostart, the closest the Wayland line gets to ohmychadwm's run.sh.
#
# Ports kiro-hyprland's look & feel — SUPER keybind grammar, Kiro app launchers
# (CTRL+ALT + SUPER+F1..F12), the waybar + mako + swaybg shell, hyprlock/hypridle
# lock pipeline — onto river's tag-based, dwm-lineage vocabulary (tags not
# workspaces; focus-view next/previous; rivertile main-ratio/main-count).
# Colours are applied live by scripts/set-theme.sh (pywal).
# See: man 1 river / riverctl / rivertile
# ────────────────────────────────────────────────────────────────────────

mod="Super"

# ── Applications & launchers ─────────────────────────────────────────────────
riverctl map normal $mod Return        spawn alacritty
riverctl map normal $mod T             spawn alacritty
riverctl map normal $mod+Shift Return  spawn thunar
riverctl map normal $mod E             spawn code
riverctl map normal $mod D             spawn "rofi -show drun"
riverctl map normal $mod Space         spawn "rofi -show drun"
riverctl map normal $mod+Shift D       spawn "rofi -show run"
riverctl map normal $mod R             spawn rofi-theme-selector
riverctl map normal Alt R              spawn rofi-theme-selector
riverctl map normal $mod V             spawn pavucontrol
riverctl map normal $mod O             spawn "hyprpicker -a"

# CTRL+ALT launchers (Kiro scheme)
riverctl map normal Control+Alt A      spawn alacritty-tweak-tool
riverctl map normal Control+Alt Q      spawn alacritty-tweak-tool
riverctl map normal Control+Alt B      spawn "brave --password-store=basic"
riverctl map normal Control+Alt C      spawn "chromium -no-default-browser-check"
riverctl map normal Control+Alt G      spawn "chromium -no-default-browser-check"
riverctl map normal Control+Alt D      spawn obs
riverctl map normal Control+Alt E      spawn archlinux-tweak-tool
riverctl map normal Control+Alt F      spawn firefox
riverctl map normal Control+Alt I      spawn kiro-iso-builder
riverctl map normal Control+Alt M      spawn "mintstick -m iso"
riverctl map normal Control+Alt O      spawn opera
riverctl map normal Control+Alt P      spawn pamac-manager
riverctl map normal Control+Alt S      spawn fish-tweak-tool
riverctl map normal Control+Alt U      spawn pavucontrol
riverctl map normal Control+Alt V      spawn vivaldi-stable
riverctl map normal Control+Alt W      spawn fastfetch-tweak-tool
riverctl map normal Control+Alt Z      spawn fastfetch-tweak-tool
riverctl map normal Control+Alt Return spawn alacritty
riverctl map normal Control+Alt T      spawn alacritty
riverctl map normal Control+Alt End    spawn "alacritty --class btop -e btop"
riverctl map normal Control+Shift Escape spawn "alacritty --class btop -e btop"

# SUPER + F1..F12 app keys (Kiro scheme)
riverctl map normal $mod F1  spawn firefox
riverctl map normal $mod F2  spawn code
riverctl map normal $mod F3  spawn inkscape
riverctl map normal $mod F4  spawn gimp
riverctl map normal $mod F5  spawn meld
riverctl map normal $mod F6  spawn vlc
riverctl map normal $mod F7  spawn virtualbox
riverctl map normal $mod F8  spawn thunar
riverctl map normal $mod F9  spawn virt-manager
riverctl map normal $mod F10 spawn spotify
riverctl map normal $mod F11 spawn "rofi -show drun"
riverctl map normal $mod F12 spawn "rofi -show drun"

# ── System & session ─────────────────────────────────────────────────────────
riverctl map normal $mod X             spawn archlinux-logout
riverctl map normal $mod+Shift X       spawn kiro-powermenu
riverctl map normal $mod+Control S     spawn kiro-keybindings
riverctl map normal Control+Alt K      spawn archlinux-logout
riverctl map normal Control+Alt L      spawn "archlinux-logout --settings"
riverctl map normal Control+Alt R      spawn archlinux-betterlockscreen

# ── Window management (river / dwm vocabulary) ───────────────────────────────
riverctl map normal $mod Q             close
riverctl map normal $mod+Shift Q       close
riverctl map normal $mod F             toggle-fullscreen
riverctl map normal $mod+Shift Space   toggle-float
riverctl map normal $mod J             focus-view next
riverctl map normal $mod K             focus-view previous
riverctl map normal $mod+Shift J       swap next
riverctl map normal $mod+Shift K       swap previous
riverctl map normal $mod+Control Return zoom

# rivertile main area: ratio + count + orientation
riverctl map normal $mod H             send-layout-cmd rivertile "main-ratio -0.05"
riverctl map normal $mod L             send-layout-cmd rivertile "main-ratio +0.05"
riverctl map normal $mod+Shift H       send-layout-cmd rivertile "main-count +1"
riverctl map normal $mod+Shift L       send-layout-cmd rivertile "main-count -1"
riverctl map normal $mod Up            send-layout-cmd rivertile "main-location top"
riverctl map normal $mod Right         send-layout-cmd rivertile "main-location right"
riverctl map normal $mod Down          send-layout-cmd rivertile "main-location bottom"
riverctl map normal $mod Left          send-layout-cmd rivertile "main-location left"

# Output (monitor) focus / send
riverctl map normal $mod Period        focus-output next
riverctl map normal $mod Comma         focus-output previous
riverctl map normal $mod+Shift Period  send-to-output next
riverctl map normal $mod+Shift Comma   send-to-output previous

# Pointer: move / resize / float
riverctl map-pointer normal $mod BTN_LEFT   move-view
riverctl map-pointer normal $mod BTN_RIGHT  resize-view
riverctl map-pointer normal $mod BTN_MIDDLE toggle-float

# ── Tags (river's workspaces — a window can hold several at once) ─────────────
for i in $(seq 1 9)
do
    tags=$((1 << ($i - 1)))
    riverctl map normal $mod $i               set-focused-tags $tags
    riverctl map normal $mod+Shift $i         set-view-tags $tags
    riverctl map normal $mod+Control $i        toggle-focused-tags $tags
    riverctl map normal $mod+Shift+Control $i toggle-view-tags $tags
done

all_tags=$(((1 << 32) - 1))
riverctl map normal $mod 0       set-focused-tags $all_tags
riverctl map normal $mod+Shift 0 set-view-tags $all_tags

# Scratchpad lives on a high, otherwise-unused tag (SUPER+U / SUPER+Shift+U).
scratch_tag=$((1 << 20))
riverctl map normal $mod U       toggle-focused-tags $scratch_tag
riverctl map normal $mod+Shift U set-view-tags $scratch_tag
all_but_scratch=$(( ((1 << 32) - 1) ^ $scratch_tag ))
riverctl spawn-tagmask $all_but_scratch

# ── Multimedia & hardware (normal + locked) ──────────────────────────────────
for mode in normal locked
do
    riverctl map $mode None XF86AudioRaiseVolume  spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
    riverctl map $mode None XF86AudioLowerVolume  spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    riverctl map $mode None XF86AudioMute         spawn "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    riverctl map $mode None XF86AudioPlay         spawn "playerctl play-pause"
    riverctl map $mode None XF86AudioNext         spawn "playerctl next"
    riverctl map $mode None XF86AudioPrev         spawn "playerctl previous"
    riverctl map $mode None XF86MonBrightnessUp   spawn "brightnessctl set 5%+"
    riverctl map $mode None XF86MonBrightnessDown spawn "brightnessctl set 5%-"
done

# ── Wallpaper (Variety) — ohmychadwm's binding scheme, ported. Shift combos also
# recolor via pywal (set-theme.sh regenerates waybar/mako/river border colours live).
riverctl map normal Alt N       spawn "variety --next"
riverctl map normal Alt Right   spawn "variety --next"
riverctl map normal Alt P       spawn "variety --previous"
riverctl map normal Alt Left    spawn "variety --previous"
riverctl map normal Alt T       spawn "variety --trash"
riverctl map normal Alt F       spawn "variety --favorite"
riverctl map normal Alt Up      spawn "variety --pause"
riverctl map normal Alt Down    spawn "variety --resume"
riverctl map normal Alt W       spawn "variety --selector"
riverctl map normal Alt+Shift N spawn 'variety --next; sleep 1; ~/.config/river/scripts/set-theme.sh "$(variety --get)"'
riverctl map normal Alt+Shift P spawn 'variety --previous; sleep 1; ~/.config/river/scripts/set-theme.sh "$(variety --get)"'
riverctl map normal Alt+Shift T spawn 'variety --trash; sleep 1; ~/.config/river/scripts/set-theme.sh "$(variety --get)"'
riverctl map normal Alt+Shift F spawn 'variety --favorite; sleep 1; ~/.config/river/scripts/set-theme.sh "$(variety --get)"'
riverctl map normal Alt+Shift U spawn '~/.config/river/scripts/set-theme.sh "$(variety --get)"'

# ── Screenshots ──────────────────────────────────────────────────────────────
riverctl map normal None  Print spawn 'grim -g "$(slurp)" - | wl-copy'
riverctl map normal $mod  Print spawn 'grim - | wl-copy'

# ── Input ────────────────────────────────────────────────────────────────────
riverctl keyboard-layout -options "grp:alt_shift_toggle,compose:caps" "us,be"
riverctl set-repeat 40 600
riverctl focus-follows-cursor normal
riverctl set-cursor-warp on-focus-change
riverctl xcursor-theme Bibata-Modern-Ice 24
riverctl input "*touchpad*" tap enabled
riverctl input "*touchpad*" natural-scroll enabled

# ── Appearance — Tokyo Night defaults (overwritten live by set-theme.sh/pywal) ─
riverctl border-width 2
riverctl background-color 0x1a1b26
riverctl border-color-focused 0x7aa2f7
riverctl border-color-unfocused 0x414868

# ── Window rules ─────────────────────────────────────────────────────────────
riverctl rule-add float -app-id "pavucontrol"
riverctl rule-add float -app-id "blueman-manager"
riverctl rule-add float -app-id "nm-connection-editor"
riverctl rule-add float -app-id "mpv"
riverctl rule-add ssd                       # prefer server-side decorations (thin borders)

# ── Autostart (session services) ─────────────────────────────────────────────
sh "$HOME/.config/river/scripts/autostart.sh"

# ── Layout generator — rivertile (built into river-classic), start it ────────
riverctl default-layout rivertile
rivertile -view-padding 6 -outer-padding 6 -main-ratio 0.5 &
